# ── FloatChat AI — Environment Template ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Local:
DATABASE_URL=postgresql+psycopg2://localhost:5432/argo
# Cloud (Render/Neon/Supabase — paste the connection string they give you):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: ollama (local) | groq (cloud, free) | openai (cloud)
LLM_PROVIDER=ollama

# Ollama (local dev):
LLM_MODEL=gemma2:2b
OLLAMA_HOST=http://localhost:11434

# Groq (cloud deployment — get free key at console.groq.com):
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (optional):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
VECTOR_STORE=persistent

# ── Frontend → Backend URL ────────────────────────────────────────────────────
# Local:
BACKEND_URL=http://127.0.0.1:8000
# Cloud (set to your Render backend URL):
# BACKEND_URL=https://floatchat-backend.onrender.com

# ── Data Processing ───────────────────────────────────────────────────────────
MAX_FLOATS=1000
MAX_DOCUMENTS=24000
BATCH_SIZE=1000

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Railway tip: use memory vector store on ephemeral disk
# VECTOR_STORE=memory

# ── Seanoe / GDAC dataset ingestion ─────────────────────────────────────────
ARGO_DATA_SOURCE_URL=https://www.seanoe.org/data/00311/42182/
ARGO_GDAC_HTTP_BASE=https://data-argo.ifremer.fr/
ARGO_INDEX_PATH=argo_synthetic-profile_index.txt
ARGO_MAX_PROFILES=250
ARGO_PROFILE_TIMEOUT_SECONDS=25

# Local downloaded snapshot mode (optional):
# ARGO_LOCAL_SNAPSHOT_DIR=/Users/you/Downloads/202601-BgcArgoSprof
# ARGO_LOCAL_GLOB=dac/**/*_Sprof.nc
